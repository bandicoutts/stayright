# Copy this file to .env.local and fill in the values.
# .env.local is never committed to GitHub.

# Supabase project URL — get from Project Settings > API at supabase.com
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon / publishable key — safe to expose client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server only, never expose client-side
SUPABASE_SERVICE_ROLE_KEY=

# Stripe secret key — server only, never expose client-side
STRIPE_SECRET_KEY=

# Stripe publishable key — safe to expose client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret — used to verify webhook payloads
# Get from Stripe Dashboard > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create products in Stripe Dashboard, then paste the price_xxx IDs here
# Monthly recurring: £2.99/month
STRIPE_PRICE_MONTHLY=
# Annual recurring: £24.99/year
STRIPE_PRICE_ANNUAL=
# Lifetime one-time: £49.99
STRIPE_PRICE_LIFETIME=

# Resend API key for transactional email
# Get from resend.com > API Keys.
# Requires stayright.app to be verified in Resend before sending. Emails are dormant until then.
RESEND_API_KEY=

# PostHog analytics — Cloud EU (GDPR-compliant)
# Get from posthog.com > Project Settings > Project API key
# Host for Cloud EU is https://eu.i.posthog.com (set automatically if omitted)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Cron job secret — Vercel passes this as Authorization: Bearer <secret> when calling cron routes
# Generate a random string: openssl rand -hex 32
CRON_SECRET=

# Supabase CLI access token — used by `npm run gen:types`
# Get from supabase.com > Account > Access Tokens
SUPABASE_ACCESS_TOKEN=

# Public URL of this app
# Local: http://localhost:3000
# Production: https://stayright.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel personal access token — used for 
# manual deploys from the command line.
# Get from vercel.com/account/tokens
VERCEL_TOKEN=