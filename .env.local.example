# Copy this file to .env.local and fill in the values.
# .env.local is never committed to GitHub.

# Supabase project URL — get from Project Settings > API at supabase.com
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon / publishable key — safe to expose client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server only, never expose client-side
SUPABASE_SERVICE_ROLE_KEY=

# Stripe secret key — server only, never expose client-side
STRIPE_SECRET_KEY=

# Stripe publishable key — safe to expose client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret — used to verify webhook payloads
STRIPE_WEBHOOK_SECRET=

# Resend API key for transactional email
RESEND_API_KEY=

# Supabase CLI access token — used by `npm run gen:types`
# Get from supabase.com > Account > Access Tokens
SUPABASE_ACCESS_TOKEN=

# Public URL of this app
# Local: http://localhost:3000
# Production: https://your-vercel-url.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
